# Copy to .env and fill in. All values are optional - the system runs in
# deterministic/dry-run mode when they are absent.

# --- LLM (optional) ---
# When set, agents use OpenAI models. When empty, deterministic fallbacks run.
OPENAI_API_KEY=
ORCHESTRATOR_MODEL=gpt-4o
SPECIALIST_MODEL=gpt-4o-mini

# --- Storage ---
# Default is local SQLite. Use a postgresql:// URL for production.
DATABASE_URL=sqlite:///career_assistant.db

# --- Application safety ---
# Never submit real applications unless this is explicitly true.
ALLOW_LIVE_APPLY=false
# Max applications per platform per day (rate-limit guardrail).
DAILY_APPLICATION_CAP=20

# --- Scraping ---
# Comma-separated default boards: indeed,linkedin,glassdoor,google,zip_recruiter
DEFAULT_JOB_SITES=indeed
# JobSpy/Indeed hard cap is 1000 results per search.
MAX_RESULTS_PER_SEARCH=50

# --- Logging ---
LOG_LEVEL=INFO

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=168

# --- Auto-apply ---
AUTO_APPLY_MIN_SCORE=0.6

# --- SMTP (for email auto-apply) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
